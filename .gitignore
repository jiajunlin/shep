# =============================================================================
# Dependencies
# =============================================================================
node_modules/
.pnpm-store/

# =============================================================================
# Build outputs
# =============================================================================
dist/
build/
# Exception: this is a source directory (services/build/*), not a build output
!packages/core/src/infrastructure/services/build/
/web/
.next/
out/
*.tsbuildinfo

# =============================================================================
# Generated files
# =============================================================================
# Note: src/domain/generated/ is TRACKED (TypeSpec-generated domain models)
# Note: apis/ is TRACKED (JSON Schema files used at runtime for YAML validation)
# These generated files are committed to ensure consistent types across environments
*.generated.*
coverage/

# =============================================================================
# Test outputs
# =============================================================================
test-results/
playwright-report/
playwright/.cache/
.playwright-mcp/
.test-artifacts/

# =============================================================================
