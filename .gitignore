# =============================================================================
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.code-workspace
*.swp
*.swo
*~

# Local agent-tool scratch dirs (not part of the project)
.cline/
.superpowers/
.continue
.continue.md
.continue/
**/.continue
**/.continue.md
**/.record-*.mjs

# =============================================================================
# OS files
