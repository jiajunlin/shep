{
  "name": "@shepai/electron",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/entry.cjs",
  "scripts": {
    "dev": "electron .",
    "compile": "node scripts/build.mjs",
    "build": "pnpm compile && node scripts/package.mjs full linux",
    "build:mac": "pnpm compile && node scripts/package.mjs full mac",
    "build:win": "pnpm compile && node scripts/package.mjs full win",
    "build:linux": "pnpm compile && node scripts/package.mjs full linux",
    "compile:apps-only": "cross-env SHEP_SHELL_VARIANT=apps-only node scripts/build.mjs",
    "build:apps-only:mac": "pnpm compile:apps-only && node scripts/package.mjs apps-only mac",
    "build:apps-only:win": "pnpm compile:apps-only && node scripts/package.mjs apps-only win",
    "build:apps-only:linux": "pnpm compile:apps-only && node scripts/package.mjs apps-only linux",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.0",
    "@anthropic-ai/claude-agent-sdk": "0.2.81",
    "@langchain/core": "^1.1.22",
    "@langchain/langgraph": "^1.1.4",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "@openrouter/ai-sdk-provider": "^2.5.1",
    "ai": "^6.0.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.6.2",
    "electron-window-state": "^5.0.3",
    "js-yaml": "^4.1.1",
    "next": "16.1.6",
    "node-notifier": "^10.0.1",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "umzug": "^3.8.2",
    "which": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "cross-env": "^10.1.0",
    "electron": "^36.9.5",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0"
  }
}
