/**
 * @module Shep.Common.Enums.WorkItem
 *
 * Defines all enums related to the Project Management domain:
 * work items, projects, cycles, modules, views, and supporting concepts.
 */
/**
 * Work Item Priority
 *
 * Urgency/importance classification for work items.
 * Ordered from highest (Urgent) to lowest (None).
 */
@doc("Priority level for work items")
enum Priority {
  @doc("Critical — requires immediate attention")
  Urgent: "Urgent",

  @doc("Important — should be addressed soon")
  High: "High",

  @doc("Normal priority")
  Medium: "Medium",

  @doc("Can wait — address when convenient")
  Low: "Low",

  @doc("No priority assigned")
  None: "None",
}

/**
 * State Group
 *
 * Fixed semantic groups that work item states must belong to.
 * Provides the foundation for analytics (burndown, velocity, completion).
 * Each project's custom states map to exactly one of these groups.
 */
@doc("Semantic group for work item states — fixed set for analytics")
enum StateGroup {
  @doc("Items not yet scheduled for work")
  Backlog: "Backlog",

  @doc("Scheduled but not yet started")
  Unstarted: "Unstarted",

  @doc("Actively being worked on")
  Started: "Started",

  @doc("Work finished successfully")
  Completed: "Completed",

  @doc("Work abandoned or no longer needed")
  Cancelled: "Cancelled",
}

/**
 * Relation Type
 *
 * Types of relationships between work items.
 * Each relation is directional: source → target.
 */
@doc("Type of relationship between two work items")
enum RelationType {
  @doc("Source blocks target from starting")
  Blocking: "Blocking",

  @doc("Related items — informational link")
  RelatesTo: "RelatesTo",

  @doc("Source is a duplicate of target")
  Duplicate: "Duplicate",

  @doc("Source must start before target")
  StartsBefore: "StartsBefore",

  @doc("Source must finish before target")
  FinishesBefore: "FinishesBefore",
}

/**
 * Estimate Type
 *
 * Estimation system used by a project.
 * Configurable per project; determines how estimate values are interpreted.
 */
@doc("Estimation system for a project")
enum EstimateType {
  @doc("Estimates disabled")
  None: "None",

  @doc("T-shirt sizing (XS, S, M, L, XL)")
  Category: "Category",

  @doc("Numeric point values (e.g., Fibonacci)")
  Points: "Points",
}

/**
 * Work Item Type Name
 *
 * Built-in work item type classifications.
 * Each project gets default types; users can configure which are active.
 */
@doc("Classification of work item types")
enum WorkItemTypeName {
  @doc("General task or to-do")
  Task: "Task",

  @doc("Defect or bug report")
  Bug: "Bug",

  @doc("User story describing desired behavior")
  Story: "Story",

  @doc("Feature request or enhancement")
  Feature: "Feature",
}

/**
 * Cycle Status
 *
 * Lifecycle states for a sprint/cycle.
 * Only one cycle per project can be Active at a time.
 */
@doc("Lifecycle status of a cycle/sprint")
enum CycleStatus {
  @doc("Planned for the future")
  Upcoming: "Upcoming",

  @doc("Currently in progress — only one per project")
  Active: "Active",

  @doc("Sprint ended")
  Completed: "Completed",
}

/**
 * Module Status
 *
 * Lifecycle states for modules (epic-like groupings).
 */
@doc("Lifecycle status of a module")
enum ModuleStatus {
  @doc("Not yet planned")
  Backlog: "Backlog",

  @doc("Scheduled for work")
  Planned: "Planned",

  @doc("Actively being worked on")
  InProgress: "InProgress",

  @doc("Temporarily suspended")
  Paused: "Paused",

  @doc("All work finished")
  Completed: "Completed",

  @doc("Abandoned or no longer relevant")
  Cancelled: "Cancelled",
}

/**
 * Epic Status
 *
 * Lifecycle states for epics (large work containers).
 */
@doc("Lifecycle status of an epic")
enum EpicStatus {
  @doc("Not yet planned")
  Backlog: "Backlog",

  @doc("Scheduled for work")
  Planned: "Planned",

  @doc("Actively being worked on")
  InProgress: "InProgress",

  @doc("All work finished")
  Completed: "Completed",

  @doc("Abandoned or no longer relevant")
  Cancelled: "Cancelled",
}

/**
 * Intake Status
 *
 * Triage states for incoming requests (IntakeItem).
 */
@doc("Triage status for incoming intake requests")
enum IntakeStatus {
  @doc("Awaiting triage decision")
  Pending: "Pending",

  @doc("Accepted and converted to a work item")
  Accepted: "Accepted",

  @doc("Declined with reason")
  Declined: "Declined",

  @doc("Marked as duplicate of existing work item")
  Duplicate: "Duplicate",
}

/**
 * PM Notification Type
 *
 * Types of in-app notifications generated by the PM system.
 * Named PmNotificationType to avoid collision with existing NotificationEventType.
 */
@doc("Type of project management notification")
enum PmNotificationType {
  @doc("Assigned to a work item")
  Assignment: "Assignment",

  @doc("Mentioned in a comment or description")
  Mention: "Mention",

  @doc("Work item state changed")
  StateChange: "StateChange",

  @doc("New comment on a watched item")
  Comment: "Comment",

  @doc("Due date is within 24 hours")
  DueDateApproaching: "DueDateApproaching",
}

/**
 * Custom Property Type
 *
 * Data types for user-defined custom fields on work items.
 */
@doc("Data type for custom properties on work items")
enum CustomPropertyType {
  @doc("Free-form text input")
  Text: "Text",

  @doc("Numeric value")
  Number: "Number",

  @doc("Single-select from predefined options")
  Dropdown: "Dropdown",

  @doc("True/false toggle")
  Boolean: "Boolean",

  @doc("Date value")
  Date: "Date",

  @doc("Select a team member")
  MemberPicker: "MemberPicker",
}

/**
 * Project Role
 *
 * Roles that a user can have within a project.
 * Determines permission levels for project operations.
 */
@doc("User role within a project")
enum ProjectRole {
  @doc("Full control — manage members, settings, and all content")
  Admin: "Admin",

  @doc("Create, read, update work items and related entities")
  Member: "Member",

  @doc("Read-only access to project content")
  Guest: "Guest",
}

/**
 * Audit Action
 *
 * Categories of auditable actions in the system.
 * Used by the audit log to classify security-relevant events.
 */
@doc("Category of auditable action for the audit log")
enum AuditAction {
  @doc("User registered an account")
  UserRegistered: "UserRegistered",

  @doc("User logged in")
  UserLoggedIn: "UserLoggedIn",

  @doc("User logged out")
  UserLoggedOut: "UserLoggedOut",

  @doc("User session expired or was invalidated")
  SessionInvalidated: "SessionInvalidated",

  @doc("Member added to a project")
  MemberAdded: "MemberAdded",

  @doc("Member removed from a project")
  MemberRemoved: "MemberRemoved",

  @doc("Member role changed within a project")
  RoleChanged: "RoleChanged",

  @doc("Project settings modified")
  ProjectSettingsChanged: "ProjectSettingsChanged",

  @doc("Project deleted")
  ProjectDeleted: "ProjectDeleted",

  @doc("Bulk operation performed")
  BulkOperation: "BulkOperation",
}

/**
 * View Layout
 *
 * Available layout types for displaying work items in the UI.
 */
@doc("Layout type for work item views")
enum ViewLayout {
  @doc("Grouped list with expandable sections")
  List: "List",

  @doc("Kanban board with draggable columns")
  Board: "Board",

  @doc("Spreadsheet-style tabular layout")
  Table: "Table",

  @doc("Monthly/weekly calendar with date-based placement")
  Calendar: "Calendar",

  @doc("Gantt chart with dependency lines")
  Timeline: "Timeline",
}
